# ===== EAKC - Enterprise AI Knowledge Continuity =====
# Environment Configuration

# Security
SECRET_KEY=change-this-to-a-random-secret-key
ADMIN_PASSWORD=admin123

# Database (default: SQLite)
DATABASE_URL=sqlite+aiosqlite:///./eakc.db
# For PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/eakc

# AI / LLM (optional - without it, local fallback works)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
USE_LOCAL_EMBEDDINGS=true

# Telegram Bot (optional - for chat-based knowledge capture)
BOT_TOKEN=

# Knowledge Extraction
CONFIDENCE_THRESHOLD=0.6
EXTRACTION_BATCH_SIZE=10

# Debug
DEBUG=true
